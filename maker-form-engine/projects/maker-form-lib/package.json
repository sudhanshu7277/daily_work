{
  "name": "@citi/maker-form-engine",
  "version": "1.0.0",
  "description": "Dynamic, metadata-driven Form Engine for Angular 17+",
  "author": "Dynamic Solutions Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
  "ng": "ng",
  "start": "ng serve",
  "build": "ng build maker-form-lib --configuration production",
  "watch": "ng build maker-form-lib --watch --configuration development",
  "test": "ng test maker-form-lib",
  "package": "npm run build && cd dist/maker-form-lib && npm pack",
  "publish-lib": "chmod +x publish.sh && ./publish.sh"
  },
  "keywords": [
    "angular",
    "dynamic-forms",
    "maker-checker",
    "metadata-driven"
  ],
  "peerDependencies": {
    "@angular/common": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/material": "^17.0.0",
    "@angular/cdk": "^17.0.0",
    "bootstrap": "^5.3.0",
    "rxjs": "^7.8.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "sideEffects": false
}