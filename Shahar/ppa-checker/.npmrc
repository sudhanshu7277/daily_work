# .npmrc — Organizational Artifactory configuration
# Uncomment and replace with your org's Artifactory npm registry URL:
# registry=https://your-org.jfrog.io/artifactory/api/npm/npm-local/

# For scoped packages (e.g. @your-org/payment-checker):
# @your-org:registry=https://your-org.jfrog.io/artifactory/api/npm/npm-local/

# Auth token — set via environment variable, never hardcode:
# //your-org.jfrog.io/artifactory/api/npm/npm-local/:_authToken=${NPM_AUTH_TOKEN}

save-exact=true
legacy-peer-deps=true
