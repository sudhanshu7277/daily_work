{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "payment-checker-demo": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/payment-checker-demo",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [{ "glob": "**/*", "input": "src/assets", "output": "/assets" }],
            "styles": [
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "500mb", "maximumError": "1gb" },
                { "type": "anyComponentStyle", "maximumWarning": "2mb", "maximumError": "4mb" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "payment-checker-demo:build:production" },
            "development": { "buildTarget": "payment-checker-demo:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "payment-checker": {
      "projectType": "library",
      "root": "projects/payment-checker",
      "sourceRoot": "projects/payment-checker/src",
      "prefix": "pc",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/payment-checker/ng-package.json"
          },
          "configurations": {
            "production": { "tsConfig": "projects/payment-checker/tsconfig.lib.prod.json" },
            "development": { "tsConfig": "projects/payment-checker/tsconfig.lib.json" }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:jest",
          "options": {
            "tsConfig": "projects/payment-checker/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
